<!-- components/calendar/calendar.wxml -->
<view 
  class="calendar-container"
  bindtouchstart="onCalendarTouchStart"
  bindtouchmove="onCalendarTouchMove"
  bindtouchend="onCalendarTouchEnd"
>
  <view class="calendar-header">
    <view class="nav-btn" hover-class="nav-btn-hover" hover-stay-time="100" bindtap="prevMonth">❮</view>
    <view class="current-month" hover-class="{{viewMode === 'week' ? '' : 'current-month-hover'}}" bindtap="openMonthPicker">
      {{monthNames[currentMonth]}} {{currentYear}}
    </view>
    <view class="nav-btn" hover-class="nav-btn-hover" hover-stay-time="100" bindtap="nextMonth">❯</view>
  </view>

  <view class="weekday-header">
    <block wx:for="{{weekdays}}" wx:key="*this">
      <view class="weekday-item">{{item}}</view>
    </block>
  </view>

  <view 
    class="calendar-days-viewport {{viewMode === 'week' ? 'week-mode' : ''}}" 
    style="height: {{viewMode === 'week' ? 100 : rowCount * 100}}rpx;"
  >
    <swiper
      class="calendar-swiper {{viewMode === 'week' ? 'week-mode' : ''}}"
      style="height: {{viewMode === 'week' ? 100 : rowCount * 100}}rpx;"
      current="{{swiperCurrent}}"
      duration="{{swiperDuration}}"
      easing-function="easeOutCubic"
      bindanimationfinish="onCalendarSwiperFinish"
      bindtouchstart="onTouchStart"
    >
      <block wx:for="{{swiperPanels}}" wx:key="key" wx:for-item="panel">
        <swiper-item class="month-panel {{viewMode === 'week' ? 'week-mode' : ''}}">
          <view 
            class="days-grid {{viewMode === 'week' ? 'week-mode' : ''}}" 
            style="transform: translateY({{viewMode === 'week' ? -activeRowIdx * 100 : 0}}rpx);"
          >
            <block wx:for="{{panel.days}}" wx:key="dateKey" wx:for-item="day">
              <view
                class="day-item {{day.fullDate === selectedDate ? 'selected' : ''}} {{day.isPast ? 'past' : ''}} {{!day.day ? 'empty' : ''}}"
                hover-class="{{!day.day ? 'none' : 'day-item-hover'}}"
                hover-stay-time="100"
                bindtap="selectDay"
                data-date="{{day.fullDate}}"
              >
                <view wx:if="{{day.day && day.holidayInfo}}" class="holiday-badge {{day.holidayInfo.type}}">
                  <text>{{day.holidayInfo.type === 'holiday' ? '休' : '班'}}</text>
                </view>
                <view class="day-num">{{day.day}}</view>
                <view
                  wx:if="{{day.day && day.memoColors && day.memoColors.length > 0}}"
                  class="memo-dots-container"
                >
                  <view wx:for="{{day.memoColors}}" wx:key="*this" class="memo-dot" style="background-color: {{item}}"></view>
                </view>
              </view>
            </block>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <view class="fold-indicator" hover-class="fold-indicator-hover" hover-stay-time="100" bindtap="toggleViewMode">
    <view class="fold-line {{viewMode === 'week' ? 'week-mode' : ''}}"></view>
  </view>

  <!-- Month Picker Panel -->
  <view wx:if="{{showMonthPicker}}" class="month-picker-mask" bindtap="closeMonthPicker">
    <view class="month-picker-panel" catchtap="stopMonthPickerTap">
      <view class="month-picker-header">
        <view
          class="year-option {{baseYear === pickerYear ? 'active' : ''}}"
          data-year="{{baseYear}}"
          bindtap="selectPickerYear"
        >
          <text>{{baseYear}}</text>
        </view>
        <view
          class="year-option {{baseYear + 1 === pickerYear ? 'active' : ''}}"
          data-year="{{baseYear + 1}}"
          bindtap="selectPickerYear"
        >
          <text>{{baseYear + 1}}</text>
        </view>
      </view>
      <view class="month-grid">
        <block wx:for="{{monthNames}}" wx:key="*this">
          <view
            class="month-option {{index === currentMonth && pickerYear === currentYear ? 'active' : ''}}"
            data-month="{{index}}"
            bindtap="selectMonth"
          >
            <text>{{item}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
