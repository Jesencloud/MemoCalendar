/* pages/index/index.wxss */
page {
  background-color: #ffffff; /* Native pure white background */
}

.container {
  padding: 30rpx 30rpx 140rpx; /* Extra bottom padding for FAB */
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #ffffff !important; /* Force pure white backdrop */
}

.header {
  margin-bottom: 30rpx;
}

.header-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1c1c1e; /* Solid iOS title color */
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 10rpx;
}

.lang-toggle {
  background: #fff;
  width: 88rpx;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 99rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #4b5563;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
}

.lang-toggle-hover {
  background: #f3f4f6;
  transform: scale(0.95);
}

.backup-icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #6b7280;
  margin-right: 28rpx;
  background: transparent;
  transition: all 0.2s ease;
  padding: 10rpx;
}

.backup-icon-btn-hover {
  opacity: 0.6;
  transform: scale(0.9);
}

/* Event / Memo Section */
.event-section {
  margin-top: 10rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  padding-left: 20rpx;
  position: relative;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 8rpx;
  background: #fa8231; /* Citrus Orange vertical bar */
  border-radius: 99rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.today-btn {
  width: 120rpx;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 99rpx;
  background: #fff1e6; /* Citrus Orange light background */
  color: #fa8231;      /* Citrus Orange text */
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.today-btn-hover {
  background: #ffe0cc;
  transform: scale(0.95);
}

.sort-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.sort-btn-hover {
  background: #e5e7eb;
  transform: scale(0.95);
}

/* Memo Cards */
.memo-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.memo-card-wrapper {
  --swipe-actions-width: 420rpx;
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 20rpx;
  background: transparent;
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.memo-card-wrapper.dragging {
  transition: none !important;
  z-index: 99;
}

.memo-card-wrapper.dragging .memo-card {
  transform: scale(1.02);
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.12);
  opacity: 1;
}

.memo-card-wrapper.dragging .swipe-actions {
  display: none !important;
}

.memo-card {
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 20rpx;
  border-left: 8rpx solid var(--memo-color, #fa8231);
  border-top: 2rpx solid var(--memo-border-color, rgba(250, 130, 49, 0.25));
  border-right: 2rpx solid var(--memo-border-color, rgba(250, 130, 49, 0.25));
  border-bottom: 2rpx solid var(--memo-border-color, rgba(250, 130, 49, 0.25));
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.02);
  transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-top-right-radius 0.22s ease, border-bottom-right-radius 0.22s ease;
  overflow: hidden;
}

.memo-card-wrapper.swiped .memo-card {
  transform: translateX(calc(0rpx - var(--swipe-actions-width)));
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: var(--swipe-actions-width);
  display: flex;
  gap: 0;
  z-index: 1;
  padding: 0;
  box-sizing: border-box;
}

.swipe-btn {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  border-radius: 0;
}

button.swipe-btn {
  width: auto !important;
  padding: 0;
  margin: 0;
  border: none;
  line-height: 1;
}

button.swipe-btn::after {
  border: none;
}

.swipe-btn.btn-share {
  background: #64748b;
}

.swipe-btn.btn-done {
  background: #73917d; /* Premium Muted Sage Green */
}

.swipe-btn.btn-delete {
  background: #ad6060; /* Premium Muted Terra Cotta Red */
}


.memo-card-wrapper.swiped .swipe-btn-hover {
  filter: brightness(0.92);
}

.swipe-actions.is-processing .swipe-btn {
  opacity: 0.55;
  pointer-events: none;
  filter: saturate(0.7);
}
.memo-card-completed .memo-card-main {
  opacity: 0.65;
}

.memo-card-completed .memo-title-inline {
  color: #9ca3af;
}

.memo-card-completed .memo-time-inline {
  color: #9ca3af;
}

.memo-card-completed .memo-location-text {
  opacity: 0.6;
}

.memo-card-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.05);
}

.memo-card-main {
  padding: 16rpx 30rpx;
}

.memo-row-inline {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  font-size: 32rpx;
  color: #d1d5db;
  margin-left: 16rpx;
  margin-right: -8rpx;
  flex-shrink: 0;
  cursor: grab;
  transition: color 0.2s ease;
}

.memo-time-inline {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  flex-shrink: 0;
}

.memo-content-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  height: 72rpx;
}

.memo-title-inline {
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 600;
  color: #1f2937;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.memo-location-text {
  display: block;
  width: 100%;
  height: 28rpx;
  line-height: 28rpx;
  font-size: 22rpx;
  color: #6b7280;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.memo-tag-inline {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--memo-color, #fa8231);
  flex-shrink: 0;
  margin-left: auto;
  max-width: 180rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* No Memos Placeholder */
.no-events {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.02);
}

.no-events-icon-wrapper {
  width: 130rpx;
  height: 130rpx;
  background: #fff1e6; /* Soft warm orange/peach tint */
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(250, 130, 49, 0.06);
  animation: floatIcon 3s ease-in-out infinite;
}

.no-events-icon {
  font-size: 68rpx;
  line-height: 1;
}

@keyframes floatIcon {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

.no-events-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.no-events-desc {
  color: #9ca3af;
  font-size: 24rpx;
  text-align: center;
  line-height: 1.5;
  max-width: 520rpx;
}

/* Floating Action Button (FAB) */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #fa8231; /* Sunny Orange */
  box-shadow: 0 8rpx 32rpx rgba(250, 130, 49, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  transition: all 0.2s ease;
}

.fab-hover {
  transform: scale(1.08) rotate(90deg);
  box-shadow: 0 12rpx 40rpx rgba(250, 130, 49, 0.35);
}

.fab-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 500;
  line-height: 1;
  margin-top: -6rpx;
}

/* Modal Popup Form */
.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 120;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end; /* Slide up from bottom */
  justify-content: center;
  animation: fadeIn 0.25s ease;
}

.modal-mask.modal-closing {
  background: transparent;
  pointer-events: none;
  animation: none;
}

.modal-panel {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.1);
  opacity: 1;
  transition: opacity 0.12s ease;
  animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden; /* Ensure inner scroll view handles all scrolling */
}

.modal-mask.modal-closing .modal-panel {
  opacity: 0;
  animation: none;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  flex-shrink: 0;
}

.form-delete-row {
  margin-top: 48rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  background: #fef2f2; /* Soft red tint */
  border: 2rpx solid rgba(214, 84, 84, 0.15);
  transition: all 0.2s ease;
}

.form-delete-row-hover {
  background: #fee2e2;
  transform: scale(0.98);
}

.form-delete-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #d65454; /* Premium Brick Red */
  letter-spacing: 2rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.modal-close {
  font-size: 56rpx;
  color: #9ca3af;
  padding: 16rpx;
  margin-top: -12rpx;
  margin-right: -12rpx;
  line-height: 1;
  transition: color 0.2s ease;
}

.modal-form {
  flex: 1;
  min-height: 0; /* Crucial for flex children scroll containers */
  overflow-y: auto;
  margin-bottom: 40rpx;
  -webkit-overflow-scrolling: touch; /* Momentum scrolling on iOS */
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.word-counter {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 400;
}

/* Form Inputs */
.input-title {
  width: 100%;
  height: 90rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
}

.tag-selector {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.tag-item {
  padding: 14rpx 20rpx;
  border-radius: 99rpx;
  background: #f3f4f6;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #4b5563;
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}

.tag-item.active {
  background: var(--tag-bg);
  border-color: var(--tag-color);
  color: var(--tag-color);
  font-weight: 600;
}

.tag-text {
  max-width: 130rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.custom-tag-item {
  position: relative;
  padding-right: 56rpx;
}

.custom-tag-item .tag-text {
  max-width: 100rpx;
}

.tag-delete-btn {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: all 0.15s ease;
}

.tag-delete-btn-hover {
  background: rgba(214, 84, 84, 0.15); /* Soft red tint */
  color: #d65454; /* Brick Red */
  transform: translateY(-50%) scale(1.08);
}

.tag-item-add {
  background: transparent;
  border: 2rpx dashed #d1d5db;
  color: #6b7280;
}

.tag-icon {
  font-size: 28rpx;
}

.picker-value,
.input-container {
  width: 100%;
  height: 90rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #111827;
}

.picker-value.placeholder {
  color: #9ca3af;
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #111827;
}

.textarea-field {
  width: 100%;
  height: 160rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.5;
}

.field-emoji {
  font-size: 32rpx;
}

/* Modal Actions */
.modal-actions {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  border-radius: 99rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s ease, filter 0.2s ease;
}

.btn-cancel {
  background: #f3f4f6;
  color: #4b5563;
}

.btn-cancel-hover {
  background: #e5e7eb;
}

.btn-save {
  background: #fa8231; /* Sunny Orange */
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(250, 130, 49, 0.25);
}



.btn-save-hover {
  filter: brightness(0.95);
}

.is-disabled {
  opacity: 0.55;
  pointer-events: none;
}

.form-item-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

/* Center alignment for custom category modal */
.custom-category-mask {
  align-items: center;
  padding: 0 50rpx;
  box-sizing: border-box;
  z-index: 130;
}

.custom-category-mask .custom-category-panel {
  width: 100%;
  max-width: 600rpx;
  border-radius: 32rpx; /* Rounded corners on all sides */
  padding: 40rpx;
  margin-bottom: 240rpx; /* Offset upwards significantly to clear keyboard safely */
  animation: modalZoomIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); /* Bounce-zoom animation */
}

@keyframes modalZoomIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.share-preview-mask {
  align-items: center;
  padding: 0 80rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.45);
  z-index: 140;
}

.share-preview-panel {
  width: 100%;
  max-width: 620rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.share-preview-body {
  max-height: 58vh;
}

.share-preview-card {
  background: #fff;
  border-left: 8rpx solid var(--memo-color, #fa8231);
  border-top: 2rpx solid var(--memo-border-color, rgba(250, 130, 49, 0.25));
  border-right: 2rpx solid var(--memo-border-color, rgba(250, 130, 49, 0.25));
  border-bottom: 2rpx solid var(--memo-border-color, rgba(250, 130, 49, 0.25));
  border-radius: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.share-preview-date {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.share-preview-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.35;
  word-break: break-word;
  margin-bottom: 24rpx;
}

.share-preview-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid #f3f4f6;
}

.share-preview-label {
  font-size: 24rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.share-preview-value {
  font-size: 26rpx;
  color: #1f2937;
  text-align: right;
  line-height: 1.45;
  word-break: break-word;
}

.share-preview-notes {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 18rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid #f3f4f6;
}

.share-preview-note-text {
  font-size: 26rpx;
  color: #1f2937;
  line-height: 1.55;
  word-break: break-word;
}

.share-preview-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-top: 24rpx;
}
.header-actions {
  display: flex;
  align-items: center;
}

/* Backup & Restore Panel styling */
.backup-panel {
  width: 100%;
  max-width: 620rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.backup-mask {
  align-items: center;
  padding: 0 80rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.45);
  z-index: 135;
}

.backup-form {
  max-height: 70vh;
  padding-bottom: 20rpx;
}

.backup-section {
  display: flex;
  flex-direction: column;
  padding: 10rpx 0;
}

.backup-sec-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.backup-sec-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.backup-btn-action {
  width: 100% !important;
  background: #fa8231 !important; /* Sunny Orange */
  color: #fff !important;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  padding: 18rpx 0;
  margin: 0 !important;
  box-shadow: 0 4rpx 12rpx rgba(250, 130, 49, 0.2);
  border: none;
}

.btn-hover {
  opacity: 0.86;
}

.backup-btn-action.btn-secondary {
  background: #f3f4f6 !important;
  color: #4b5563 !important;
  box-shadow: none;
  border: 2rpx solid #e5e7eb;
}

.backup-divider {
  height: 2rpx;
  background: #f3f4f6;
  margin: 30rpx 0;
}

.backup-manual-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #4b5563;
  margin: 24rpx 0 12rpx;
}

.backup-textarea {
  width: 100%;
  height: 180rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #374151;
  font-family: monospace;
  margin-bottom: 24rpx;
}

.backup-import-actions {
  display: flex;
  gap: 20rpx;
}

.backup-import-actions .import-btn {
  flex: 1;
  font-size: 26rpx;
