<!--pages/index/index.wxml-->
<page-meta page-style="overflow: {{modalVisible || modalClosing || confirmDialog.visible || backupModalVisible ? 'hidden' : 'visible'}}" />
<view class="container {{lang === 'zh' ? 'lang-zh' : 'lang-en'}}">
  <view class="header">
    <view class="header-main">
      <view>
        <text class="title">{{text.title}}</text>
        <text class="subtitle">{{text.subtitle}}</text>
      </view>
      <view class="header-actions">
        <view class="lang-toggle" hover-class="lang-toggle-hover" hover-stay-time="100" bindtap="onOpenBackupModal" style="margin-right: 15rpx;">
          <text>⚙️ {{text.backupBtn}}</text>
        </view>
        <view class="lang-toggle" hover-class="lang-toggle-hover" hover-stay-time="100" bindtap="toggleLang">
          <text>{{text.langToggle}}</text>
        </view>
      </view>
    </view>
  </view>

  <calendar
     id="calendar"
     lang="{{lang}}"
     selectedDate="{{selectedDate}}"
     memoDates="{{memoDates}}"
     bind:selectdate="onDateSelect"
   />

  <view class="event-section">
    <view class="section-header">
      <view class="section-title">
        <text>{{selectedDate}} {{text.events}}</text>
      </view>
      <view class="section-actions">
        <view wx:if="{{selectedMemos.length > 1}}" class="sort-btn" hover-class="sort-btn-hover" hover-stay-time="100" bindtap="sortByTime">
          <text>⏳</text>
        </view>
        <view wx:if="{{showTodayButton}}" class="today-btn" hover-class="today-btn-hover" hover-stay-time="100" bindtap="goToday">
          <text>{{text.today}}</text>
        </view>
      </view>
    </view>
    
    <view wx:if="{{selectedMemos.length > 0}}" class="memo-list">
      <block wx:for="{{selectedMemos}}" wx:key="id">
        <view
          class="memo-card-wrapper {{item.id === swipedMemoId ? 'swiped' : ''}} {{item.id === draggingId ? 'dragging' : ''}}"
          data-id="{{item.id}}"
          data-index="{{index}}"
          bindtouchstart="onSwipeTouchStart"
          bindtouchend="onSwipeTouchEnd"
          style="transform: translateY({{item.id === draggingId ? dragTranslateY : 0}}px); z-index: {{item.id === draggingId ? 99 : 1}};"
        >
          <view
            class="memo-card {{item.completed ? 'memo-card-completed' : ''}}"
            hover-class="{{item.id === swipedMemoId || draggingId ? 'none' : 'memo-card-hover'}}"
            data-id="{{item.id}}"
            bindtap="onEditMemoTap"
            style="border-left: 8rpx solid {{item.completed ? '#d1d5db' : (item.color || '#d09a04')}}; border-top: 2rpx solid {{item.completed ? '#e5e7eb' : (item.color || '#d09a04')}}40; border-right: 2rpx solid {{item.completed ? '#e5e7eb' : (item.color || '#d09a04')}}40; border-bottom: 2rpx solid {{item.completed ? '#e5e7eb' : (item.color || '#d09a04')}}40;"
          >
            <view class="memo-card-main">
              <view class="memo-row-inline">
                <text class="memo-time-inline" wx:if="{{item.time}}">{{item.time}}</text>
                <text class="memo-title-inline">{{item.title}}</text>
                <view class="memo-location-inline" wx:if="{{item.location}}">
                  <text class="location-text">{{item.location}}</text>
                </view>
                <text class="memo-tag-inline" style="color: {{item.completed ? '#d1d5db' : item.color}}">{{item.categoryIcon === '🏷️' ? '#' + (lang === 'zh' ? item.tagCn : item.tagEn) : item.categoryIcon}}</text>
                <view
                  class="drag-handle"
                  catchtouchstart="onDragStart"
                  catchtouchmove="onDragMove"
                  catchtouchend="onDragEnd"
                  data-id="{{item.id}}"
                  data-index="{{index}}"
                >
                  <text>☰</text>
                </view>
              </view>
            </view>
          </view>
          
          <view class="swipe-actions">
            <view class="swipe-btn btn-done" catchtap="onSwipeDoneTap" data-id="{{item.id}}">
              <text>{{item.completed ? text.todo : text.done}}</text>
            </view>
            <view class="swipe-btn btn-delete" catchtap="onSwipeDeleteTap" data-id="{{item.id}}">
              <text>{{text.delete}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
    
    <view wx:else class="no-events">
      <text class="no-events-icon">📝</text>
      <text class="no-events-text">{{text.noEvents}}</text>
    </view>
  </view>

  <!-- Floating Add Button -->
  <view class="fab" hover-class="fab-hover" hover-stay-time="100" bindtap="onAddMemoTap">
    <text class="fab-icon">+</text>
  </view>

  <!-- Memo Edit/Add Modal -->
  <view wx:if="{{modalVisible || modalClosing}}" class="modal-mask {{modalClosing ? 'modal-closing' : ''}}">
    <view class="modal-panel">
      <view class="modal-header">
        <text class="modal-title">{{memoForm.id ? text.editMemo : text.addMemo}}</text>
        <view class="modal-header-actions">
          <view wx:if="{{memoForm.id}}" class="modal-delete-icon" bindtap="onDeleteMemo">🗑️</view>
          <view class="modal-close" catchtap="closeModal">×</view>
        </view>
      </view>
      
      <scroll-view scroll-y class="modal-form">
        <!-- Title Input -->
        <view class="form-item">
          <input
            class="input-title"
            placeholder="{{text.inputTitlePlaceholder}}"
            value="{{memoForm.title}}"
            bindinput="onFormTitleInput"
            cursor-spacing="20"
            maxlength="40"
          />
        </view>

        <!-- Completed Switch -->
        <view class="form-item form-item-switch" wx:if="{{memoForm.id}}">
          <text class="form-label">{{text.markCompleted}}</text>
          <switch checked="{{memoForm.completed}}" bindchange="onFormCompletedChange" color="#d09a04" />
        </view>
        
        <!-- Category Selector -->
        <view class="form-item">
          <text class="form-label">{{text.selectCategory}}</text>
          <view class="tag-selector">
            <view
              wx:for="{{categories}}"
              wx:key="key"
              class="tag-item {{memoForm.tag === item.key ? 'active' : ''}} {{item.isCustom ? 'custom-tag-item' : ''}}"
              style="--tag-color: {{item.color}}; --tag-bg: {{item.color}}15"
              data-key="{{item.key}}"
              bindtap="onSelectTag"
            >
              <text class="tag-icon">{{item.icon}}</text>
              <text class="tag-text">{{lang === 'zh' ? item.labelCn : item.labelEn}}</text>
              <!-- Delete icon for custom categories -->
              <view
                wx:if="{{item.isCustom}}"
                class="tag-delete-btn"
                catchtap="onDeleteCustomTag"
                data-key="{{item.key}}"
                data-name="{{item.labelCn}}"
              >×</view>
            </view>
            <!-- Add Custom Category Tag Button -->
            <view
              class="tag-item tag-item-add"
              bindtap="onAddCustomTag"
            >
              <text class="tag-icon">＋</text>
              <text class="tag-text">{{text.customCategory}}</text>
            </view>
          </view>
        </view>
        
        <!-- Time Picker -->
        <view class="form-item">
          <text class="form-label">{{text.time}}</text>
          <picker mode="time" value="{{memoForm.time}}" bindchange="onFormTimeChange">
            <view class="picker-value {{memoForm.time ? '' : 'placeholder'}}">
              <text class="field-emoji">⏰</text>
              <text>{{memoForm.time || text.inputTimePlaceholder}}</text>
            </view>
          </picker>
        </view>
        
        <!-- Location Input -->
        <view class="form-item">
          <text class="form-label">{{text.location}}</text>
          <view class="input-container">
            <text class="field-emoji">📌</text>
            <input
              class="input-field"
              placeholder="{{text.inputLocationPlaceholder}}"
              value="{{memoForm.location}}"
              bindinput="onFormLocationInput"
              cursor-spacing="30"
              maxlength="100"
            />
          </view>
        </view>
        
        <!-- Notes Input -->
        <view class="form-item">
          <view class="form-label-row">
            <text class="form-label">{{text.notes}}</text>
            <text class="word-counter">{{memoNotesLength}}/200</text>
          </view>
          <textarea
            class="textarea-field"
            placeholder="{{text.inputNotesPlaceholder}}"
            value="{{memoForm.notes}}"
            bindinput="onFormNotesInput"
            maxlength="200"
            fixed="{{true}}"
            cursor-spacing="50"
          />
        </view>
      </scroll-view>
      
      <view class="modal-actions">
        <view
          class="modal-btn btn-cancel"
          hover-class="btn-cancel-hover"
          catchtap="closeModal"
        >
          {{text.cancel}}
        </view>
        <view
          class="modal-btn btn-save"
          hover-class="btn-save-hover"
          catchtap="onSaveMemo"
        >
          {{text.save}}
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Category Modal -->
  <view class="modal-mask custom-category-mask" wx:if="{{customCategoryModalVisible}}" catchtouchmove="stopBubble" style="z-index: 130;">
    <view class="modal-panel custom-category-panel">
      <view class="modal-header">
        <text class="modal-title">{{text.newCustomCategory}}</text>
      </view>

      <scroll-view scroll-y class="modal-form" style="padding-bottom: 20rpx;">
        <view class="form-item">
          <input
            class="input-title"
            placeholder="{{text.customCategoryPlaceholder}}"
            value="{{customCategoryName}}"
            bindinput="onCustomCategoryNameInput"
            maxlength="10"
            cursor-spacing="20"
            focus="{{customCategoryModalVisible}}"
          />
        </view>
      </scroll-view>

      <view class="modal-actions">
        <view
          class="modal-btn btn-cancel"
          hover-class="btn-cancel-hover"
          catchtap="onCloseCustomCategoryModal"
        >
          {{text.cancel}}
        </view>
        <view
          class="modal-btn btn-save"
          hover-class="btn-save-hover"
          catchtap="onSaveCustomCategory"
        >
          {{text.confirm}}
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Confirmation Dialog -->
  <view class="modal-mask custom-confirm-mask" wx:if="{{confirmDialog.visible}}" catchtouchmove="stopBubble" style="z-index: 140;">
    <view class="modal-panel custom-confirm-panel">
      <view class="modal-header">
        <text class="modal-title">{{confirmDialog.title}}</text>
      </view>

      <view class="modal-body custom-confirm-body">
        <text class="confirm-content-text">{{confirmDialog.content}}</text>
      </view>

      <view class="modal-actions">
        <view
          class="modal-btn btn-cancel"
          hover-class="btn-cancel-hover"
          catchtap="onConfirmDialogCancel"
        >
          {{confirmDialog.cancelText}}
        </view>
        <view
          class="modal-btn btn-save"
          hover-class="btn-save-hover"
          style="background: {{confirmDialog.confirmColor}}; box-shadow: 0 6rpx 20rpx {{confirmDialog.confirmColor}}40;"
          catchtap="onConfirmDialogConfirm"
        >
          {{confirmDialog.confirmText}}
        </view>
      </view>
    </view>
  </view>

  <!-- Data Backup & Restore Modal -->
  <view class="modal-mask custom-confirm-mask" wx:if="{{backupModalVisible}}" catchtouchmove="stopBubble" style="z-index: 135;">
    <view class="modal-panel backup-panel">
      <view class="modal-header">
        <text class="modal-title">{{text.dataBackupTitle}}</text>
        <view class="modal-close" catchtap="onCloseBackupModal">×</view>
      </view>

      <scroll-view scroll-y class="modal-form" style="max-height: 70vh; padding-bottom: 20rpx;">
        <!-- Export Section -->
        <view class="backup-section">
          <text class="backup-sec-title">📤 {{text.exportData}}</text>
          <text class="backup-sec-desc">{{text.exportDesc}}</text>
          <button class="backup-btn-action" hover-class="btn-hover" bindtap="onExportData">
            {{text.copyBackupData}}
          </button>
        </view>

        <!-- Divider -->
        <view class="backup-divider"></view>

        <!-- Import Section -->
        <view class="backup-section">
          <text class="backup-sec-title">📥 {{text.importData}}</text>
          <text class="backup-sec-desc">{{text.importDesc}}</text>

          <button class="backup-btn-action btn-secondary" hover-class="btn-hover" bindtap="onImportFromClipboard">
            📋 {{text.importFromClipboard}}
          </button>

          <view class="backup-manual-label">{{text.manualPasteLabel}}:</view>
          <textarea
            class="backup-textarea"
            placeholder="{{text.pastePlaceholder}}"
            value="{{importInputText}}"
            bindinput="onImportTextInput"
            maxlength="-1"
            disable-default-padding="{{true}}"
          />

          <view class="backup-import-actions">
            <button class="import-btn merge-btn" hover-class="btn-hover" bindtap="onTriggerMergeImport">
              {{text.mergeImport}}
            </button>
            <button class="import-btn overwrite-btn" hover-class="btn-hover" bindtap="onTriggerOverwriteImport">
              {{text.overwriteImport}}
            </button>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

</view>
