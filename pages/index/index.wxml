<!--pages/index/index.wxml-->
<page-meta page-style="overflow: {{modalVisible || modalClosing || backupModalVisible || sharePreviewVisible ? 'hidden' : 'visible'}}" />
<view class="container {{lang === 'zh' ? 'lang-zh' : 'lang-en'}}">
  <view class="header">
    <view class="header-main">
      <view>
        <text class="title">{{text.title}}</text>
        <text class="subtitle">{{text.subtitle}}</text>
      </view>
      <view class="header-actions">
        <view class="backup-icon-btn" hover-class="backup-icon-btn-hover" hover-stay-time="100" bindtap="onOpenBackupModal">
          <text>💾</text>
        </view>
        <view class="lang-toggle" hover-class="lang-toggle-hover" hover-stay-time="100" bindtap="toggleLang">
          <text>{{text.langToggle}}</text>
        </view>
      </view>
    </view>
  </view>

  <calendar
     id="calendar"
     lang="{{lang}}"
     selectedDate="{{selectedDate}}"
     memoDateMeta="{{memoDateMeta}}"
     bind:selectdate="onDateSelect"
   />

  <view class="event-section">
    <view class="section-header">
      <view class="section-title">
        <text>{{selectedDate}} {{text.events}}</text>
      </view>
      <view class="section-actions">
        <view wx:if="{{selectedMemos.length > 1}}" class="sort-btn" hover-class="sort-btn-hover" hover-stay-time="100" bindtap="sortByTime">
          <text>⇅</text>
        </view>
        <view wx:if="{{showTodayButton}}" class="today-btn" hover-class="today-btn-hover" hover-stay-time="100" bindtap="goToday">
          <text>{{text.today}}</text>
        </view>
      </view>
    </view>
    
    <view wx:if="{{selectedMemos.length > 0}}" class="memo-list">
      <block wx:for="{{selectedMemos}}" wx:key="id">
        <view
          class="memo-card-wrapper {{item.id === swipedMemoId ? 'swiped' : ''}} {{item.id === draggingId ? 'dragging' : ''}}"
          data-id="{{item.id}}"
          data-index="{{index}}"
          bindtouchstart="onSwipeTouchStart"
          bindtouchend="onSwipeTouchEnd"
          style="transform: translateY({{item.id === draggingId ? dragTranslateY : 0}}px);"
        >
          <view
            class="memo-card {{item.completed ? 'memo-card-completed' : ''}}"
            hover-class="{{item.id === swipedMemoId || draggingId ? 'none' : 'memo-card-hover'}}"
            data-id="{{item.id}}"
            bindtap="onEditMemoTap"
            style="--memo-color: {{item.completed ? '#d1d5db' : (item.color || '#fa8231')}}; --memo-border-color: {{item.completed ? '#e5e7eb' : (item.color || '#fa8231') + '40'}};"
          >
            <view class="memo-card-main">
              <view class="memo-row-inline">
                <text class="memo-time-inline" wx:if="{{item.time}}">{{item.time}}</text>
                <view class="memo-content-column">
                  <text class="memo-title-inline">{{item.title}}</text>
                  <view class="memo-location-row" wx:if="{{item.location}}">
                    <text class="memo-location-icon">📍</text>
                    <text class="memo-location-text">{{item.location}}</text>
                  </view>
                </view>
                <text class="memo-tag-inline">{{item.categoryIcon === '🏷️' ? (lang === 'zh' ? item.tagCn : item.tagEn) : item.categoryIcon}}</text>
                <view
                  class="drag-handle"
                  catchtouchstart="onDragStart"
                  catchtouchmove="onDragMove"
                  catchtouchend="onDragEnd"
                  data-id="{{item.id}}"
                  data-index="{{index}}"
                >
                  <text>☰</text>
                </view>
              </view>
            </view>
          </view>
          
          <view class="swipe-actions">
            <button
              class="swipe-btn btn-share"
              open-type="share"
              data-id="{{item.id}}"
              data-date="{{selectedDate}}"
              hover-class="none"
            >
              <text>{{text.shareMemo}}</text>
            </button>
            <view class="swipe-btn btn-done" catchtap="onSwipeDoneTap" data-id="{{item.id}}">
              <text>{{item.completed ? text.todo : text.done}}</text>
            </view>
            <view class="swipe-btn btn-delete" catchtap="onSwipeDeleteTap" data-id="{{item.id}}">
              <text>{{text.delete}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
    
    <view wx:else class="no-events">
      <view class="no-events-icon-wrapper">
        <text class="no-events-icon">📝</text>
      </view>
      <text class="no-events-title">{{text.noEventsTitle}}</text>
      <text class="no-events-desc">{{text.noEventsDesc}}</text>
    </view>
  </view>

  <!-- Floating Add Button -->
  <view class="fab" hover-class="fab-hover" hover-stay-time="100" bindtap="onAddMemoTap">
    <text class="fab-icon">+</text>
  </view>

  <!-- Memo Edit/Add Modal -->
  <view wx:if="{{modalVisible || modalClosing}}" class="modal-mask {{modalClosing ? 'modal-closing' : ''}}">
    <view class="modal-panel">
      <view class="modal-header">
        <text class="modal-title">{{memoForm.id ? text.editMemo : text.addMemo}}</text>
        <view class="modal-close" catchtap="closeModal">×</view>
      </view>
      
      <scroll-view scroll-y class="modal-form">
        <!-- Title Input -->
        <view class="form-item">
          <input
            class="input-title"
            placeholder="{{text.inputTitlePlaceholder}}"
            value="{{memoForm.title}}"
            bindinput="onFormTitleInput"
            cursor-spacing="20"
            maxlength="40"
          />
        </view>

        <!-- Completed Switch -->
        <view class="form-item form-item-switch" wx:if="{{memoForm.id}}">
          <text class="form-label">{{text.markCompleted}}</text>
          <switch checked="{{memoForm.completed}}" bindchange="onFormCompletedChange" color="#fa8231" />
        </view>
        
        <!-- Category Selector -->
        <view class="form-item">
          <text class="form-label">{{text.selectCategory}}</text>
          <view class="tag-selector">
            <view
              wx:for="{{categories}}"
              wx:key="key"
              class="tag-item {{memoForm.tag === item.key ? 'active' : ''}} {{item.isCustom ? 'custom-tag-item' : ''}}"
              style="--tag-color: {{item.color}}; --tag-bg: {{item.color}}15"
              data-key="{{item.key}}"
              bindtap="onSelectTag"
              bindlongpress="onLongPressTag"
            >
              <text class="tag-icon" wx:if="{{item.icon !== '🏷️'}}">{{item.icon}}</text>
              <text class="tag-text">{{lang === 'zh' ? item.labelCn : item.labelEn}}</text>
              <!-- Delete icon for custom categories -->
              <view
                wx:if="{{item.isCustom}}"
                class="tag-delete-btn"
                hover-class="tag-delete-btn-hover"
                catchtap="onDeleteCustomTag"
                data-key="{{item.key}}"
                data-name="{{item.labelCn}}"
              >×</view>
            </view>
            <!-- Add Custom Category Tag Button -->
            <view
              class="tag-item tag-item-add"
              bindtap="onAddCustomTag"
            >
              <text class="tag-icon">＋</text>
              <text class="tag-text">{{text.customCategory}}</text>
            </view>
          </view>
        </view>
        
        <!-- Time Picker -->
        <view class="form-item">
          <text class="form-label">{{text.time}}</text>
          <picker mode="time" value="{{memoForm.time}}" bindchange="onFormTimeChange">
            <view class="picker-value {{memoForm.time ? '' : 'placeholder'}}">
              <text class="field-emoji">⏰</text>
              <text>{{memoForm.time || text.inputTimePlaceholder}}</text>
            </view>
          </picker>
        </view>
        
        <!-- Location Input -->
        <view class="form-item">
          <text class="form-label">{{text.location}}</text>
          <view class="input-container">
            <text class="field-emoji">📌</text>
            <input
              class="input-field"
              placeholder="{{text.inputLocationPlaceholder}}"
              value="{{memoForm.location}}"
              bindinput="onFormLocationInput"
              cursor-spacing="30"
              maxlength="100"
            />
          </view>
        </view>
        
        <!-- Notes Input -->
        <view class="form-item">
          <view class="form-label-row">
            <text class="form-label">{{text.notes}}</text>
            <text class="word-counter">{{memoNotesLength}}/200</text>
          </view>
          <textarea
            class="textarea-field"
            placeholder="{{text.inputNotesPlaceholder}}"
            value="{{memoForm.notes}}"
            bindinput="onFormNotesInput"
            maxlength="200"
            fixed="{{true}}"
            cursor-spacing="50"
          />
        </view>
        <!-- Delete Button -->
        <view wx:if="{{memoForm.id}}" class="form-delete-row" hover-class="form-delete-row-hover" bindtap="onDeleteMemo">
          <text class="form-delete-text">{{text.delete}}</text>
        </view>
      </scroll-view>
      
      <view class="modal-actions">
        <view
          class="modal-btn btn-cancel"
          hover-class="btn-cancel-hover"
          catchtap="closeModal"
        >
          {{text.cancel}}
        </view>
        <view
          class="modal-btn btn-save {{savingMemo ? 'is-disabled' : ''}}"
          hover-class="{{savingMemo ? 'none' : 'btn-save-hover'}}"
          catchtap="onSaveMemo"
        >
          {{text.save}}
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Category Modal -->
  <view class="modal-mask custom-category-mask" wx:if="{{customCategoryModalVisible}}" catchtouchmove="stopBubble">
    <view class="modal-panel custom-category-panel">
      <view class="modal-header">
        <text class="modal-title">{{editingCategoryKey ? text.editCustomCategory : text.newCustomCategory}}</text>
      </view>

      <scroll-view scroll-y class="modal-form" style="padding-bottom: 20rpx;">
        <view class="form-item">
          <input
            class="input-title"
            placeholder="{{text.customCategoryPlaceholder}}"
            value="{{customCategoryName}}"
            bindinput="onCustomCategoryNameInput"
            maxlength="10"
            cursor-spacing="20"
            focus="{{customCategoryModalVisible}}"
          />
        </view>
      </scroll-view>

      <view class="modal-actions">
        <view
          class="modal-btn btn-cancel"
          hover-class="btn-cancel-hover"
          catchtap="onCloseCustomCategoryModal"
        >
          {{text.cancel}}
        </view>
        <view
          class="modal-btn btn-save {{savingCategory ? 'is-disabled' : ''}}"
          hover-class="{{savingCategory ? 'none' : 'btn-save-hover'}}"
          catchtap="onSaveCustomCategory"
        >
          {{text.confirm}}
        </view>
      </view>
    </view>
  </view>

  <!-- Shared Memo Preview Modal -->
  <view class="modal-mask share-preview-mask" wx:if="{{sharePreviewVisible}}" catchtouchmove="stopBubble">
    <view class="modal-panel share-preview-panel">
      <view class="modal-header">
        <text class="modal-title">{{text.sharedMemoTitle}}</text>
        <view class="modal-close" catchtap="onCloseSharePreview">×</view>
      </view>

      <scroll-view scroll-y class="modal-form share-preview-body">
        <view
          class="share-preview-card"
          style="--memo-color: {{sharedMemo.completed ? '#d1d5db' : (sharedMemo.color || '#fa8231')}}; --memo-border-color: {{sharedMemo.completed ? '#e5e7eb' : (sharedMemo.color || '#fa8231') + '40'}};"
        >
          <text class="share-preview-date">{{sharedMemoDate}}</text>
          <text class="share-preview-title">{{sharedMemo.title}}</text>

          <view class="share-preview-row" wx:if="{{sharedMemo.time}}">
            <text class="share-preview-label">{{text.time}}</text>
            <text class="share-preview-value">{{sharedMemo.time}}</text>
          </view>

          <view class="share-preview-row" wx:if="{{sharedMemo.location}}">
            <text class="share-preview-label">{{text.location}}</text>
            <text class="share-preview-value">{{sharedMemo.location}}</text>
          </view>

          <view class="share-preview-row">
            <text class="share-preview-label">{{text.selectCategory}}</text>
            <text class="share-preview-value">{{sharedMemo.categoryIcon === '🏷️' ? '#' + (lang === 'zh' ? sharedMemo.tagCn : sharedMemo.tagEn) : sharedMemo.categoryIcon}}</text>
          </view>

          <view class="share-preview-notes" wx:if="{{sharedMemo.notes}}">
            <text class="share-preview-label">{{text.notes}}</text>
            <text class="share-preview-note-text">{{sharedMemo.notes}}</text>
          </view>
        </view>

        <text class="share-preview-desc">{{text.sharedMemoDesc}}</text>
      </scroll-view>

      <view class="modal-actions">
        <view
          class="modal-btn btn-cancel"
          hover-class="btn-cancel-hover"
          catchtap="onCloseSharePreview"
        >
          {{text.cancel}}
        </view>
        <view
          class="modal-btn btn-save {{savingSharedMemo ? 'is-disabled' : ''}}"
          hover-class="{{savingSharedMemo ? 'none' : 'btn-save-hover'}}"
          catchtap="onSaveSharedMemo"
        >
          {{text.addSharedMemo}}
        </view>
      </view>
    </view>
  </view>
  <!-- Data Backup & Restore Modal -->
  <view class="modal-mask backup-mask" wx:if="{{backupModalVisible}}" catchtouchmove="stopBubble">
    <view class="modal-panel backup-panel">
      <view class="modal-header">
        <text class="modal-title">{{text.dataBackupTitle}}</text>
        <view class="modal-close" catchtap="onCloseBackupModal">×</view>
      </view>

      <scroll-view scroll-y class="modal-form backup-form">
        <!-- Export Section -->
        <view class="backup-section">
          <text class="backup-sec-title">📤 {{text.exportData}}</text>
          <text class="backup-sec-desc">{{text.exportDesc}}</text>
          <button
            class="backup-btn-action {{exportingData || importingData ? 'is-disabled' : ''}}"
            hover-class="{{exportingData || importingData ? 'none' : 'btn-hover'}}"
            disabled="{{exportingData || importingData}}"
            loading="{{exportingData}}"
            bindtap="onExportData"
          >
            {{text.copyBackupData}}
          </button>
        </view>

        <!-- Divider -->
        <view class="backup-divider"></view>

        <!-- Import Section -->
        <view class="backup-section">
          <text class="backup-sec-title">📥 {{text.importData}}</text>
          <text class="backup-sec-desc">{{text.importDesc}}</text>

          <button
            class="backup-btn-action btn-secondary {{exportingData || importingData ? 'is-disabled' : ''}}"
            hover-class="{{exportingData || importingData ? 'none' : 'btn-hover'}}"
            disabled="{{exportingData || importingData}}"
            loading="{{importingData}}"
            bindtap="onImportFromClipboard"
          >
            📋 {{text.importFromClipboard}}
          </button>

          <view class="backup-manual-label">{{text.manualPasteLabel}}:</view>
          <textarea
            class="backup-textarea"
            placeholder="{{text.pastePlaceholder}}"
            value="{{importInputText}}"
            bindinput="onImportTextInput"
            maxlength="-1"
            disabled="{{exportingData || importingData}}"
            disable-default-padding="{{true}}"
          />

          <view class="backup-import-actions">
            <button
              class="import-btn merge-btn {{exportingData || importingData ? 'is-disabled' : ''}}"
              hover-class="{{exportingData || importingData ? 'none' : 'btn-hover'}}"
              disabled="{{exportingData || importingData}}"
              loading="{{importingData}}"
              bindtap="onTriggerMergeImport"
            >
              {{text.mergeImport}}
            </button>
            <button
              class="import-btn overwrite-btn {{exportingData || importingData ? 'is-disabled' : ''}}"
              hover-class="{{exportingData || importingData ? 'none' : 'btn-hover'}}"
              disabled="{{exportingData || importingData}}"
              loading="{{importingData}}"
              bindtap="onTriggerOverwriteImport"
            >
              {{text.overwriteImport}}
            </button>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

</view>
